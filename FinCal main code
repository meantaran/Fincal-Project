        const handleCalculate = async () => {
        let res = null;
        try {
        switch (activeTab) {
        case 'sip':
        res = FinanceEngine.calculateSIP(inputs.monthly, inputs.rate, inputs.years);
        break;
        case 'swp':
        res = FinanceEngine.calculateSWP(inputs.initial, inputs.withdrawal, inputs.rate, inputs.years);
