// --- FINANCIAL CALCULATORS ENGINE ---
const FinanceEngine = {
calculateSIP: (monthly, rate, years) => {
const r = rate / 12 / 100;
const n = Math.max(0, years * 12);
const futureValue = r === 0 ? monthly * n : monthly * ((Math.pow(1 + r, n) - 1) / r) * (1 + r);
const totalInvested = monthly * n;
return {
futureValue: Math.round(futureValue || 0),
totalInvestment: Math.round(totalInvested || 0),
returns: Math.round((futureValue - totalInvested) || 0)
};
},

calculateSWP: (initial, withdrawal, rate, years) => {
const r = rate / 12 / 100;
const n = Math.max(0, years * 12);
let balance = initial;
const schedule = [];

for (let i = 1; i <= n; i++) { balance=(balance * (1 + r)) - withdrawal; if (balance <=0) { balance=0; if (i % 12===0 ||
    i===n) schedule.push({ year: Math.ceil(i / 12), balance: 0 }); break; } if (i % 12===0) schedule.push({ year: i /
    12, balance: Math.round(balance) }); } return { remainingBalance: Math.round(balance || 0), totalWithdrawn:
    withdrawal * (schedule.length> 0 ? (schedule[schedule.length - 1].year * 12) : 0),
    schedule
    };
    },

    calculateTopUpSIP: (monthly, rate, years, topUpPct) => {
    const r = rate / 12 / 100;
    let totalValue = 0;
    let totalInvested = 0;
    let currentMonthly = monthly;
    const yearlyData = [];

    for (let y = 1; y <= years; y++) { for (let m=1; m <=12; m++) { totalValue=(totalValue + currentMonthly) * (1 + r);
        totalInvested +=currentMonthly; } yearlyData.push({ year: y, value: Math.round(totalValue), invested:
        totalInvested }); currentMonthly=currentMonthly * (1 + (topUpPct / 100)); } return { futureValue:
        Math.round(totalValue || 0), totalInvestment: Math.round(totalInvested || 0), returns: Math.round((totalValue -
        totalInvested) || 0), yearlyData }; }, calculateGoal: (target, rate, years)=> {
        const r = rate / 12 / 100;
        const n = Math.max(1, years * 12);
        const denom = r === 0 ? n : (((Math.pow(1 + r, n) - 1) / r) * (1 + r));
        const requiredMonthly = target / denom;
        return {
        requiredMonthly: Math.round(requiredMonthly || 0)
        };
        },

        calculateRetirement: (currentAge, retireAge, expenses, returnRate) => {
        const yearsToRetire = Math.max(0, retireAge - currentAge);
        const lifeExpectancy = 85;
        const yearsInRetirement = Math.max(0, lifeExpectancy - retireAge);
        const inflation = 0.06;

        const monthlyExpensesAtRetirement = expenses * Math.pow(1 + inflation, yearsToRetire);
        const postRetireReturn = 0.08;
        const realRate = (1 + postRetireReturn) / (1 + inflation) - 1;
        const monthlyRealRate = realRate / 12;
        const monthsInRetirement = yearsInRetirement * 12;

        const corpusNeeded = monthlyRealRate === 0
        ? monthlyExpensesAtRetirement * monthsInRetirement
        : monthlyExpensesAtRetirement * ((1 - Math.pow(1 + monthlyRealRate, -monthsInRetirement)) / monthlyRealRate);

        const r = returnRate / 12 / 100;
        const n = yearsToRetire * 12;
        const denom = n === 0 ? 1 : (r === 0 ? n : (((Math.pow(1 + r, n) - 1) / r) * (1 + r)));
        const monthlySIP = corpusNeeded / denom;

        return {
        corpusNeeded: Math.round(corpusNeeded || 0),
        monthlyInvestment: Math.round(monthlySIP || 0),
        expensesAtRetirement: Math.round(monthlyExpensesAtRetirement || 0)
        };
        }
        };

