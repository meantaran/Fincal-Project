                    ) : (
                    <div
                        className="bg-white p-12 rounded-xl border-2 border-dashed border-gray-200 flex flex-col items-center justify-center text-center print:hidden">
                        <Calculator size={48} className="text-gray-300 mb-4" />
                        <h3 className="text-xl font-bold text-gray-400">Ready to calculate</h3>
                        <p className="text-gray-400 max-w-xs mt-2">Adjust inputs and click calculate to view
                            projections.</p>
                    </div>
                    )}
                </div>
            </div>
            );

            const renderHistory = () => (
            <div className="p-6 max-w-5xl mx-auto print:hidden">
                <div className="flex items-center justify-between mb-8">
                    <h2 className="text-2xl font-bold text-[#224c87]">Calculation History</h2>
                    <HistoryIcon className="text-[#919090]" />
                </div>
                <div className="grid gap-4">
                    {history.length > 0 ? history.map((item) => (
                    <div key={item.id}
                        className="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex flex-wrap justify-between items-center gap-4">
                        <div className="flex items-center gap-4">
                            <div
                                className="h-10 w-10 rounded-full bg-[#224c87]/10 flex items-center justify-center text-[#224c87]">
                                <Calculator size={20} />
                            </div>
                            <div>
                                <h4 className="font-bold text-gray-800 capitalize">{item.type} Calculator</h4>
                                <p className="text-xs text-gray-500">{item.timestamp?.toDate().toLocaleDateString()}</p>
                            </div>
                        </div>
                        <div className="flex gap-8">
                            <div className="text-center">
                                <p className="text-[10px] text-gray-500 uppercase font-bold">Basis</p>
                                <p className="font-semibold text-gray-800">₹{(item.inputs?.monthly ||
                                    item.inputs?.initial || item.inputs?.target || 0).toLocaleString()}</p>
                            </div>
                            <div className="text-center">
                                <p className="text-[10px] text-gray-500 uppercase font-bold">Result</p>
                                <p className="font-semibold text-[#224c87]">₹{(item.results?.futureValue ||
                                    item.results?.requiredMonthly || item.results?.corpusNeeded || 0).toLocaleString()}
                                </p>
                            </div>
                        </div>
                        <button onClick={()=> { setInputs(item.inputs); setResults(item.results);
                            setActiveTab(item.type); }} className="px-4 py-2 text-sm font-semibold text-[#da3832] border
                            border-[#da3832] rounded-lg hover:bg-[#da3832] hover:text-white transition-colors">
                            Reload
                        </button>
                    </div>
                    )) : <div className="text-center py-20 bg-white rounded-xl">
                        <p className="text-gray-400">No history found.</p>
                    </div>}
                </div>
            </div>
            );

            return (
            <div className="min-h-screen bg-[#f3f4f6] font-sans print:bg-white">
                <style>
                    {
                        ` @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap');

                        body {
                            font-family: 'Montserrat', sans-serif;
                        }

                        @media print {
                            @page {
                                size: A4;
                                margin: 2cm;
                            }

                            body {
                                background-color: white !important;
                            }

                            .recharts-responsive-container {
                                width: 100% !important;
                                height: 400px !important;
                            }

                            main {
                                margin: 0 !important;
                                padding: 0 !important;
                            }

                            .flex {
                                display: block !important;
                            }

                            * {
                                -webkit-print-color-adjust: exact !important;
                                print-color-adjust: exact !important;
                            }
                        }

                        `
                    }
                </style>
                <Navbar activeTab={activeTab} setActiveTab={setActiveTab} setSidebarOpen={setSidebarOpen} />
                <div className="flex">
                    <Sidebar activeTab={activeTab} setActiveTab={setActiveTab} isOpen={sidebarOpen}
                        setIsOpen={setSidebarOpen} />
                    <main className="flex-1 transition-all duration-300">
                        <div className="p-4 lg:p-8">
                            {activeTab === 'dashboard' && renderDashboard()}
                            {activeTab === 'history' && renderHistory()}
                            {['sip', 'swp', 'topup', 'goal', 'retirement'].includes(activeTab) &&
                            renderCalculatorForm()}
                        </div>
                    </main>
                </div>
            </div>
            );
            }
